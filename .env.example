# Generate with: python -c "from config import Config; print(Config.generate_fernet_key())"
FERNET_KEY=

# Flask
SECRET_KEY=change-me-in-production
DATABASE_URL=postgresql://user:password@localhost/content_distributor

# OpusClip
OPUSCLIP_API_KEY=

# YouTube OAuth (from Google Cloud Console)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
# Change to https://your-app.onrender.com/auth/youtube/callback when deployed
YOUTUBE_REDIRECT_URI=http://localhost:5000/auth/youtube/callback

# Instagram / Meta (from Meta Developer Portal)
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# TikTok (from TikTok Developer Portal — requires Content Posting API approval)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Telegram (optional — leave blank to disable notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
